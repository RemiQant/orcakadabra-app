# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── FastAPI / CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URL here once it is provisioned.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://orcakadabra-app.vercel.app

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# SERVICE ROLE key has full DB access — backend only, never expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
# Dashboard: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kyc-documents

# ── Alibaba Cloud Model Studio (Qwen-VL) ──────────────────────────────────────
# Dashboard: Model Studio → API Keys
DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_VL_MODEL=qwen-vl-plus

# ── Misc ───────────────────────────────────────────────────────────────────────
APP_ENV=development   # development | production
