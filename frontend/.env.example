# Copy this file to .env.development or .env.production and fill in real values.
# Prefix ALL frontend env vars with VITE_ so Vite exposes them to the browser bundle.
# NEVER put secrets here — this is shipped to the user's browser.

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8080

# Supabase (public anon key — safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
